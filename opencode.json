{
  "$schema": "https://opencode.ai/config.json",
  "shell": "pwsh",
  "skills": {
    "paths": [
      "../sphere/.opencode/skills",
      "../../sphere/.opencode/skills",
      "../../../sphere/.opencode/skills",
      "../../../../sphere/.opencode/skills"
    ]
  },
  "instructions": ["./AGENTS.md"],
  "agent": {
    "rinoa": {
      "mode": "primary",
      "hidden": true,
      "description": "Rinoa — OLS Customer Support Reply Agent ตอบคำถามลูกค้าด้วย DNA จาก OpenLandscape Cloud FAQ",
      "model": "anthropic/claude-sonnet-4-20250514",
      "temperature": 0.2,
      "prompt": "{file:./agents/rinoa-reply.md}",
      "permission": {
        "read": "allow",
        "skill": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "edit": "ask",
        "bash": "deny",
        "task": {
          "*": "deny",
          "quistis": "allow",
          "laguna": "allow"
        }
      }
    },
    "quistis": {
      "mode": "subagent",
      "hidden": true,
      "model": "anthropic/claude-haiku-4-20250514",
      "prompt": "{file:./agents/quistis-research.md}"
    },
    "laguna": {
      "mode": "subagent",
      "hidden": true,
      "model": "anthropic/claude-haiku-4-20250514",
      "prompt": "{file:./agents/laguna-writer.md}"
    }
  },
  "command": {
    "laguna": {
      "template": "บันทึกความรู้ใหม่ที่ค้นพบจาก research ครั้งล่าสุด โดยจัดหมวดหมู่และเพิ่ม keywords ภาษาไทย $ARGUMENTS",
      "description": "Save new knowledge from research into knowledge/ directory",
      "agent": "laguna"
    }
  },
  "permission": {
    "bash": {
      "*": "deny"
    }
  }
}
